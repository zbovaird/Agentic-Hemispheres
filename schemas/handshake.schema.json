{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zbovaird/Agentic-Hemispheres/schemas/handshake.schema.json",
  "title": "Corpus Callosum handshake (implementer return / planning)",
  "type": "object",
  "required": ["schema_version", "intent_id", "architectural_constraint", "target_files", "acceptance_criteria"],
  "properties": {
    "schema_version": { "type": "string" },
    "intent_id": { "type": "string" },
    "architectural_constraint": { "type": "string" },
    "target_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "implementation_proof": {
      "type": "object",
      "properties": {
        "test_log": { "type": "string" },
        "diff_summary": { "type": "string" },
        "lint_status": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
